{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": {
        "owner": "esbuild",
        "source": "esbuild",
        "applyTo": "closedDocuments",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^\\s*(.*):([0-9]+):([0-9]+): (warning|error): (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[watch\\] build started",
          "endsPattern": "\\[watch\\] build finished"
        }
      },
      "isBackground": true,
      "label": "npm: watch",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "never"
      }
    },
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$esbuild",
      "label": "npm: compile",
      "group": "build"
    },
    {
      "type": "npm",
      "script": "compile-tests",
      "problemMatcher": "$tsc",
      "label": "npm: compile-tests",
      "group": "build"
    },
    {
      "type": "npm",
      "script": "lint",
      "problemMatcher": "$eslint-stylish",
      "label": "npm: lint",
      "group": "test"
    }
  ]
}
